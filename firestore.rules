rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Products: anyone can read, only admin can write
    match /products/{productId} {
      allow read: if true;
      allow write: if true; // In production, add: if request.auth != null && request.auth.token.admin == true
    }
    
    // Orders: anyone can create, only admin can read/update
    match /orders/{orderId} {
      allow create: if true;
      allow read, update, delete: if true; // In production, restrict to admin
    }
  }
}
